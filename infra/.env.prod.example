# Copyright Nisse Group Ltd
# Copy to infra/.env.prod for the single-VPS docker-compose deployment.
# NEVER commit the filled-in file.

# Public domain Caddy serves the hub + API on (TLS is automatic).
SPAKWUS_DOMAIN=spakwus.ca

# Postgres superuser password for the bundled database.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Comma-separated steward bearer tokens for the moderation API (/api/admin).
STEWARD_TOKENS=change-me-steward-token

LOG_LEVEL=info

# --- Optional integrations (leave blank to disable) ---
# LLM classification of report notes (deterministic keyword stub when unset).
ANTHROPIC_API_KEY=

# Web push (VAPID). Generate: docker run --rm node:20-slim npx -y web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Email double opt-in + alerts (Resend).
RESEND_API_KEY=

# Telegram bot (public channel broadcast + subscriber DMs).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel

# --- Operator uptime alerts (any subset) ---
# Generic webhook (Slack/Discord/PagerDuty) receiving { "text": "..." }.
OPERATOR_WEBHOOK_URL=
# Or email the operator (needs RESEND_API_KEY).
OPERATOR_EMAIL=
