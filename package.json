{
  "name": "spakwus",
  "version": "0.0.0",
  "private": true,
  "description": "Spakwus — Sea to Sky Highway (BC Highway 99) live conditions hub and community board. A product of Nisse Group Ltd.",
  "author": "Nisse Group Ltd",
  "license": "SEE LICENSE IN README.md",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "build:shared": "pnpm --filter @nissegroup/shared run build",
    "build:core": "pnpm --filter @nissegroup/core run build",
    "build:hub": "pnpm --filter @nissegroup/hub run build",
    "test:shared": "pnpm --filter @nissegroup/shared run test",
    "dev:core": "pnpm --filter @nissegroup/core run dev",
    "dev:hub": "pnpm --filter @nissegroup/hub run dev",
    "start:core": "pnpm --filter @nissegroup/core run start"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4"
  }
}
