# Copyright Nisse Group Ltd
# Copy to .env for local development.

# Postgres 16 + PostGIS (see docker-compose.yml)
DATABASE_URL=postgres://spakwus:spakwus@localhost:5432/spakwus

# Test database used by the integration suite (docker-compose service postgres-test).
# When unset, the DB-backed integration tests are skipped.
TEST_DATABASE_URL=postgres://spakwus:spakwus@localhost:5433/spakwus_test

# Redis
REDIS_URL=redis://localhost:6379

# HTTP server
HOST=0.0.0.0
PORT=3000

# Workers
ENABLE_WORKERS=true
OPEN511_URL=https://api.open511.gov.bc.ca/events
OPEN511_POLL_MS=60000
WEBCAM_REFRESH_MS=120000

# Steward auth — comma-separated bearer tokens for the /api/admin moderation API.
# A device token matching one of these also makes a web report count as a steward
# report. Leave empty to disable the admin API (returns 503).
STEWARD_TOKENS=dev-steward

# Public report rate limits (per rolling window, via Redis; fails open if Redis down).
REPORT_RATE_WINDOW_SEC=600
REPORT_RATE_MAX_IP=10
REPORT_RATE_MAX_TOKEN=5

# LLM classification of report notes. When ANTHROPIC_API_KEY is unset, a
# deterministic keyword stub is used. deriveStatus never calls the LLM.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# --- Notifications ---
# Public base URL used in alert deep links, and where verify links redirect.
PUBLIC_BASE_URL=http://localhost:5173
NOTIFY_POLL_MS=10000
QUIET_HOURS_START=22
QUIET_HOURS_END=7

# --- Observability ---
# Structured JSON log level (pino): fatal|error|warn|info|debug|trace|silent.
LOG_LEVEL=info

# --- Read cache (short-TTL Redis cache for /api/status and /api/status/snapshot) ---
# Busted immediately on every status write; 0 disables the cache.
STATUS_CACHE_TTL_SEC=10

# --- Static fallback snapshot (fail-to-stale-but-honest) ---
# Where to publish the last-known corridor status so the hub survives a backend
# outage. file = write SNAPSHOT_FILE; http = also PUT to SNAPSHOT_HTTP_URL; none.
SNAPSHOT_PUBLISH=file
SNAPSHOT_FILE=./public/status-fallback.json
SNAPSHOT_PUBLISH_MS=20000
# SNAPSHOT_HTTP_URL=https://spakwus.ca/status-fallback.json
# SNAPSHOT_HTTP_TOKEN=

# --- Operator uptime alerting ---
OPEN511_STALE_ALERT_SEC=600
HEALTH_MONITOR_MS=60000
ALERT_COOLDOWN_SEC=1800
# Any subset of sinks (generic webhook receives { "text": "..." }).
# OPERATOR_WEBHOOK_URL=
# OPERATOR_EMAIL=
# OPERATOR_TELEGRAM_CHAT_ID=

# Web push (VAPID). Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@nissegroup.example

# Email (Resend). Without a key, confirmation + alert emails are logged (dev).
# RESEND_API_KEY=
EMAIL_FROM=Spakwus <alerts@nissegroup.example>

# Telegram: bot posts every alert to a public channel and DMs subscribers.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=@your_channel
# TELEGRAM_BOT_USERNAME=your_bot

# SMS (Twilio) — OFF by default, behind a flag.
ENABLE_SMS=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
