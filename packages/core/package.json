{
  "name": "@nissegroup/core",
  "version": "0.0.0",
  "private": true,
  "description": "Spakwus backend — Fastify API, Drizzle/Postgres+PostGIS, Redis, and the two-plane ingestion/derivation service. A product of Nisse Group Ltd.",
  "author": "Nisse Group Ltd",
  "license": "SEE LICENSE IN README.md",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate-cli.ts",
    "load:history": "tsx scripts/load-history.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@nissegroup/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "postgres": "^3.4.5",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
