{
  "name": "@nissegroup/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types, the deterministic status state machine, and brand config for Spakwus. A product of Nisse Group Ltd.",
  "author": "Nisse Group Ltd",
  "license": "SEE LICENSE IN README.md",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
